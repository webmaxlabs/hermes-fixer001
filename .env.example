# inbox-watcher secrets — copy to ~/.config/inbox-watcher/.env on agent001 (chmod 600)
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=fixer001@agentmail.to
SLACK_BOT_TOKEN=xoxb-...
SLACK_DIGEST_CHANNEL=#hermes-digest
# Optional overrides:
# INBOX_WATCHER_DATA_DIR=
# INBOX_WATCHER_FINDINGS_DIR=
# INBOX_WATCHER_HEARTBEAT_PATH=

# --- Spec 2 Phase A: dry-run dispatcher ---
# HMAC key for signing dispatch payloads (random 32+ bytes). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# The dispatcher fails closed (exit 2) if this is empty.
HERMES_FIXER_DISPATCH_SECRET=
# dry_run (default) | live (Phase B — requires CODEX_BIN + GITHUB_TOKEN; opens draft PRs)
DISPATCH_MODE=dry_run

# --- Spec 2 Phase B: agent001-hosted Codex fixer ---
# DISPATCH_MODE=live enables the fixer (leave dry_run until Codex + token are set).
CODEX_BIN=codex
CODEX_TIMEOUT_SEC=600
# Fine-grained PAT scoped to the fixer-eligible repos (contents + pull_requests write).
GITHUB_TOKEN=
FIXER_PR_LABELS=hermes-fixer
FIXER_DEFAULT_OWNER=webmaxlabs
